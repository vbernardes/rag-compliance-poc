# LLM selection: "ollama" (default), "mistral", or "anthropic"
LLM_PROVIDER=ollama
OLLAMA_MODEL=mistral-nemo

# Only required when LLM_PROVIDER=mistral
# Embeddings also switch to mistral-embed when this provider is active
MISTRAL_API_KEY=
MISTRAL_MODEL=open-mistral-nemo

# Only required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Retrieval tuning
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
